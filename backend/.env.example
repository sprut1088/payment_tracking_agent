# Prototype uses SQLite by default.
# For production, replace with PostgreSQL configuration.
ENVIRONMENT=local

# ---------------------------------------------------------------------------
# LLM provider for Tier 2c AI adjudication
# ---------------------------------------------------------------------------
# Choose provider: "openrouter" (default) or "anthropic"
LLM_PROVIDER=openrouter

# Model name — must match the provider's format:
#   openrouter examples : openai/gpt-4o-mini  |  anthropic/claude-3.5-sonnet
#   anthropic examples  : claude-3-5-sonnet-20241022  |  claude-3-haiku-20240307
LLM_MODEL=openai/gpt-4o-mini

# Max tokens for LLM response. Claude is more verbose; 300 is safer than 120.
LLM_MAX_TOKENS=300

# API key for OpenRouter (used when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# API key for Anthropic direct (used when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

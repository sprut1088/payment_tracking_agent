# ── .env.docker.example ───────────────────────────────────────────────────────
# Copy this file to .env.docker and fill in your actual values.
# The docker-compose.yml loads .env.docker automatically (required: false).
#
#   cp .env.docker.example .env.docker
#
# Never commit .env.docker to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Application environment
PTA_ENVIRONMENT=docker

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose "openai" (for OpenAI direct or OpenRouter) or "anthropic".
PTA_LLM_PROVIDER=openai

# Model name — format depends on provider:
#   openai / openrouter : openai/gpt-4o-mini  |  anthropic/claude-3.5-sonnet
#   anthropic direct    : claude-3-5-sonnet-20241022
PTA_LLM_MODEL=openai/gpt-4o-mini

# Max tokens for LLM responses.
PTA_LLM_MAX_TOKENS=300

# ── API Keys ──────────────────────────────────────────────────────────────────
# OpenAI / OpenRouter key (used when PTA_LLM_PROVIDER=openai)
# PTA_LLM_API_KEY=your-openrouter-or-openai-api-key-here

# Anthropic key (used when PTA_LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

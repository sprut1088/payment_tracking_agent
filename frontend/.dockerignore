# Frontend .dockerignore
# Excludes files that should not be sent to the Docker build context.

# Dependencies — reinstalled inside the image via npm ci
node_modules/

# Build output — produced inside the image during docker build
dist/
.vite/

# TypeScript incremental build info
*.tsbuildinfo

# Environment files
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS / editor metadata
.DS_Store
Thumbs.db
.vscode/
.idea/

# Git
.git/
.gitignore

# Logs
*.log
npm-debug.log*
